# Copy to a local environment file and edit for your lab.

AUTOPROBER_DASHBOARD_HOST=0.0.0.0
AUTOPROBER_DASHBOARD_PORT=5000

AUTOPROBER_CNC_PORT=/dev/ttyUSB0
AUTOPROBER_CNC_BAUD=115200

AUTOPROBER_SCOPE_HOST=127.0.0.1
AUTOPROBER_SCOPE_PORT=5025
AUTOPROBER_ENDSTOP_CHANNEL=4
AUTOPROBER_POGO_CHANNEL=1

AUTOPROBER_MICROSCOPE_DEV=/dev/video0
AUTOPROBER_MICROSCOPE_SNAPSHOT_URL=http://127.0.0.1:8080/?action=snapshot
AUTOPROBER_MICROSCOPE_STREAM_URL=http://127.0.0.1:8080/?action=stream

AUTOPROBER_LOG_PATH=~/.local/state/autoprober/autoprober.log
AUTOPROBER_RUNTIME_ROOT=~/.local/share/autoprober
